//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// DST Hidden Markov Model v4 — XAUUSD
// ═══════════════════════════════════════════════════════════════════════════
// CHANGELOG v4 (dari v3):
//
//   [BUG FIX #1] Duration Smoothing — cur_dur tidak bertambah saat transisi ditolak
//     SEBELUM: saat nxt != cur_state && cur_dur < min_d, cur_dur tidak diupdate
//     SESUDAH: cur_dur += 1 tetap dijalankan meski transisi ditolak
//     EFEK: state tidak lagi terkunci permanen, transisi bisa terjadi setelah
//           durasi minimum terpenuhi
//
//   [BUG FIX #2] Duration Counter (VDUR) — dihitung dari vpath yang sudah dipatch
//     SEBELUM: VDUR menghitung berapa bar terakhir di vpath (sudah dimodifikasi
//              smoothing), sehingga melaporkan durasi yang diinflasi
//     SESUDAH: VDUR dihitung dari raw_vpath (Viterbi asli sebelum smoothing)
//              untuk mencerminkan durasi sesungguhnya menurut model
//     EFEK: durasi 57b palsu tidak akan muncul lagi
//
//   [BUG FIX #3] cur_dur Reset yang Salah — setelah transisi diterima
//     SEBELUM: cur_dur := 1 saat ganti state (seharusnya mulai dari 1 tapi
//              perlu konsisten dengan counting logic)
//     SESUDAH: cur_dur := 1 dipertahankan tapi dengan counting yang benar
//              (cur_dur selalu bertambah di setiap bar, baik transisi diterima/ditolak)
//
//   [NEW] raw_vpath — simpan Viterbi path asli sebelum smoothing untuk diagnostik
//   [NEW] VDUR_RAW — durasi berdasarkan Viterbi asli (ditampilkan di tabel)
//   [NEW] Tampilkan VDUR_RAW vs VDUR di banner untuk deteksi smoothing lock
// ═══════════════════════════════════════════════════════════════════════════
indicator("DST HMM v4 - XAUUSD (Duration Fixed)", overlay = true, max_labels_count = 500)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_h = "HMM Training"
grp_f = "Feature Settings"
grp_a = "ATR & SL/TP"
grp_d = "Display"
grp_p = "Table Positions"

hmm_win     = input.int(150,  "Training Window (bars)",      minval=20, maxval=500, group=grp_h)
bw_n        = input.int(3,    "Baum-Welch Iterations",       minval=1,  maxval=20,  group=grp_h)
sig_floor   = input.float(0.30,"Min Emission sigma",         minval=0.01, maxval=2.0, step=0.05, group=grp_h)
stat_pow    = input.int(30,   "Stationary Power (A^n)",      minval=10, maxval=100, group=grp_h)
min_dur_s   = input.int(2,    "Min Duration - Sideways (bars)", minval=1, maxval=50, group=grp_h,
              tooltip="[v4] Default turun 5→2. Sideways boleh lebih cepat berubah.")
min_dur_b   = input.int(1,    "Min Duration - Bull/Bear (bars)",minval=1, maxval=50, group=grp_h,
              tooltip="[v4] Default turun 3→1. Jangan tahan Bull/Bear terlalu lama, biarkan model bergerak bebas.")
reg_str     = input.float(0.30,"Regularization Strength",    minval=0.0, maxval=0.5, step=0.05, group=grp_h)
min_occ_pct = input.float(0.05,"Min State Occupancy (%T)",   minval=0.01, maxval=0.3, step=0.01, group=grp_h)
temp_scale  = input.float(3.0, "Posterior Temperature",      minval=0.5, maxval=10.0, step=0.5, group=grp_h,
              tooltip="Temperature scaling posterior γ. Rekomendasi: 2.0-4.0")

z_win       = input.int(20,   "Z-Score Window",              minval=5,  maxval=100, group=grp_f)
ema_len     = input.int(21,   "EMA Length (untuk slope)",    minval=5,  maxval=100, group=grp_f)
slope_per   = input.int(14,   "Slope Lookback (bars)",       minval=1,  maxval=50,  group=grp_f,
              tooltip="[v4] Default naik 5→14. Slope jangka lebih panjang = lebih representatif trend sesungguhnya.")
atr_len_f   = input.int(14,   "ATR Length (fitur)",          minval=1,  maxval=50,  group=grp_f)

atr_len_sl  = input.int(14,   "ATR Length (SL/TP)",          minval=1,  maxval=50,  group=grp_a)
atr_bull    = input.float(1.2,"ATR Mult - Bull",             minval=0.5, maxval=5.0, step=0.1, group=grp_a)
atr_bear    = input.float(1.5,"ATR Mult - Bear",             minval=0.5, maxval=5.0, step=0.1, group=grp_a)
rr_r        = input.float(2.0,"Risk Reward Ratio",           minval=1.0, maxval=10.0, step=0.5, group=grp_a)
show_sltp   = input.bool(true,"Tampilkan DST Kalkulasi",     group=grp_a)

show_rib    = input.bool(true, "Regime Ribbon",              group=grp_d)
show_warn   = input.bool(true, "Sideways Warning",           group=grp_d)
show_ban    = input.bool(true, "Regime Banner",              group=grp_d)
show_mat    = input.bool(true, "Transition Matrix",          group=grp_d)
show_stat   = input.bool(true, "Stationary Distribution",   group=grp_d)
show_emit   = input.bool(true, "Emission Parameters",        group=grp_d)
show_lbl    = input.bool(true, "Label Transitions",          group=grp_d)
min_hold    = input.int(4,    "Min Hold Bars (debounce)",    minval=1, maxval=50, group=grp_d)
tsize       = input.string("normal","Table Text Size",
              options=["small","normal","large","huge"],     group=grp_d)

ban_ps = input.string("top_left",    "Banner",     options=["top_left","top_center","top_right","middle_left","middle_center","middle_right","bottom_left","bottom_center","bottom_right"], group=grp_p)
mat_ps = input.string("top_right",   "Matrix",     options=["top_left","top_center","top_right","middle_left","middle_center","middle_right","bottom_left","bottom_center","bottom_right"], group=grp_p)
stt_ps = input.string("bottom_right","Stationary", options=["top_left","top_center","top_right","middle_left","middle_center","middle_right","bottom_left","bottom_center","bottom_right"], group=grp_p)
slt_ps = input.string("bottom_left", "SL/TP",      options=["top_left","top_center","top_right","middle_left","middle_center","middle_right","bottom_left","bottom_center","bottom_right"], group=grp_p)
emt_ps = input.string("middle_right","Emission",   options=["top_left","top_center","top_right","middle_left","middle_center","middle_right","bottom_left","bottom_center","bottom_right"], group=grp_p)

// ─── HELPERS ─────────────────────────────────────────────────────────────────
gpos(s) =>
    switch s
        "top_left"      => position.top_left
        "top_center"    => position.top_center
        "top_right"     => position.top_right
        "middle_left"   => position.middle_left
        "middle_center" => position.middle_center
        "middle_right"  => position.middle_right
        "bottom_left"   => position.bottom_left
        "bottom_center" => position.bottom_center
        => position.bottom_right

gsz(s) =>
    switch s
        "small"  => size.small
        "normal" => size.normal
        "large"  => size.large
        => size.huge

gszh(s) =>
    switch s
        "huge"  => size.large
        "large" => size.normal
        => size.small

mm3(A3, B3) =>
    C3 = array.new_float(9, 0.0)
    for r3 = 0 to 2
        for c3 = 0 to 2
            s3 = 0.0
            for k3 = 0 to 2
                s3 += array.get(A3, r3*3+k3) * array.get(B3, k3*3+c3)
            array.set(C3, r3*3+c3, s3)
    C3

fmtp(p) => str.tostring(math.round(p * 100)) + "%"
fmtf(v) => str.tostring(math.round(v * 100) / 100.0, "#.##")
fmtd(v) => str.tostring(math.round(v * 10) / 10.0, "#.#") + "b"

sv = gsz(tsize)
sh = gszh(tsize)

// ─── PALETTE ─────────────────────────────────────────────────────────────────
CB  = color.rgb(132, 187, 161)
CR  = color.rgb(197, 127, 134)
CS  = color.rgb(164, 171, 183)
CK  = color.new(#0B0F0D, 8)
CF  = color.new(#3FDE7E, 78)
CA  = #3FDE7E
CDG = color.new(#3FDE7E, 80)
CDT = #6BF0A6
COF = color.new(color.white, 55)
CHD = color.new(color.white, 35)
CFT = color.new(color.white, 60)
CWN = color.rgb(255, 200, 0, 88)
CWT = color.white

rgc(r)  => r == 1 ? CB  : r == 2 ? CR  : CS
rgn(r)  => r == 1 ? "BULL" : r == 2 ? "BEAR" : "SIDEWAYS"
rgi(r)  => r == 1 ? "BULL" : r == 2 ? "BEAR" : "SIDEWAYS"
rgd(r)  =>
    if r == 1
        "SL = ATR x" + str.tostring(atr_bull,"#.#") + "  |  IKUTI NAIK"
    else if r == 2
        "SL = ATR x" + str.tostring(atr_bear,"#.#") + "  |  IKUTI TURUN"
    else
        "SIDEWAYS - DON'T TRADE"
rgs(r)  => r == 1 ? "BIAS BUY" : r == 2 ? "BIAS SELL" : "DON'T TRADE"
rgsc(r) => r == 1 ? CB : r == 2 ? CR : color.rgb(255, 200, 0)

// ─── FEATURE COMPUTATION (D=3) ───────────────────────────────────────────────
// Feature 0: Return Z-score
lr      = close > 0 and close[1] > 0 ? math.log(close / close[1]) : 0.0
lr_mu   = ta.sma(lr, z_win)
lr_sd   = ta.stdev(lr, z_win)
z_ret   = lr_sd > 1e-10 ? (lr - lr_mu) / lr_sd : 0.0

// Feature 1: ATR Z-score
atr_raw  = ta.atr(atr_len_f)
atr_mu   = ta.sma(atr_raw, z_win)
atr_sd   = ta.stdev(atr_raw, z_win)
z_atr    = atr_sd > 1e-10 ? (atr_raw - atr_mu) / atr_sd : 0.0

// Feature 2: EMA Slope Z-score
// [v4] slope_per default 5→14 agar slope lebih merepresentasikan trend sesungguhnya
ema_val   = ta.ema(close, ema_len)
slope_raw = atr_raw > 1e-10 ? (ema_val - ema_val[slope_per]) / (slope_per * atr_raw) : 0.0
slope_mu  = ta.sma(slope_raw, z_win)
slope_sd  = ta.stdev(slope_raw, z_win)
z_slope   = slope_sd > 1e-10 ? (slope_raw - slope_mu) / slope_sd : 0.0

// ─── OBSERVATION STORAGE ─────────────────────────────────────────────────────
var array<float> OB1 = array.new_float(0)
var array<float> OB2 = array.new_float(0)
var array<float> OB3 = array.new_float(0)

array.push(OB1, z_ret)
array.push(OB2, z_atr)
array.push(OB3, z_slope)
if array.size(OB1) > hmm_win
    array.shift(OB1)
    array.shift(OB2)
    array.shift(OB3)

// ─── HMM PARAMETERS ──────────────────────────────────────────────────────────
var array<float> HP  = array.from(0.40, 0.30, 0.30)
var array<float> HA  = array.from(0.70, 0.15, 0.15, 0.20, 0.65, 0.15, 0.20, 0.15, 0.65)
var array<float> HMU = array.from(
     0.0, -0.3,  0.0,
     0.6,  0.4,  0.5,
    -0.6,  0.4, -0.5)
var array<float> HSG = array.from(
    0.8, 0.9, 0.8,
    1.2, 1.2, 1.2,
    1.2, 1.2, 1.2)

var array<float> PRIOR_MU = array.from(
     0.0, -0.3,  0.0,
     0.6,  0.4,  0.5,
    -0.6,  0.4, -0.5)
var array<float> PRIOR_SG = array.from(
    0.8, 0.9, 0.8,
    1.2, 1.2, 1.2,
    1.2, 1.2, 1.2)

var int   VR      = 0
var float VC      = 0.40
var float VCH     = 0.40
var array<float> VP = array.from(0.40, 0.30, 0.30)
var int   VDUR    = 0      // durasi dari smoothed path
var int   VDUR_RAW = 0     // [v4 NEW] durasi dari Viterbi asli (lebih akurat)

// ─── EMISSION FUNCTIONS ──────────────────────────────────────────────────────
var float LG2PI3 = 1.5 * math.log(2.0 * math.pi)

log_mvg(o1, o2, o3, s) =>
    s0  = math.max(array.get(HSG, s*3+0), 1e-10)
    s1  = math.max(array.get(HSG, s*3+1), 1e-10)
    s2  = math.max(array.get(HSG, s*3+2), 1e-10)
    d0  = (o1 - array.get(HMU, s*3+0)) / s0
    d1  = (o2 - array.get(HMU, s*3+1)) / s1
    d2  = (o3 - array.get(HMU, s*3+2)) / s2
    -math.log(s0) - math.log(s1) - math.log(s2) - 0.5*(d0*d0 + d1*d1 + d2*d2) - LG2PI3

mvg_pdf(o1, o2, o3, s) =>
    lv = log_mvg(o1, o2, o3, s)
    lv > -500.0 ? math.exp(lv) : 1e-200

calc_conf_entropy(vp_arr) =>
    h = 0.0
    for s = 0 to 2
        p = math.max(array.get(vp_arr, s), 1e-10)
        h -= p * math.log(p)
    1.0 - (h / math.log(3.0))

apply_temperature(vp_arr, T) =>
    sum_t = 0.0
    for s = 0 to 2
        v = math.pow(math.max(array.get(vp_arr, s), 1e-300), 1.0 / T)
        array.set(vp_arr, s, v)
        sum_t += v
    sum_t := math.max(sum_t, 1e-300)
    for s = 0 to 2
        array.set(vp_arr, s, array.get(vp_arr, s) / sum_t)

// ─── MAIN HMM ────────────────────────────────────────────────────────────────
if barstate.islast
    T = math.min(array.size(OB1), hmm_win)
    N = 3

    if T >= 10

        // ── Baum-Welch EM ─────────────────────────────────────────
        for _it = 0 to bw_n - 1
            al  = array.new_float(T * N, 0.0)
            sc  = array.new_float(T, 1e-300)
            s0v = 0.0
            for s = 0 to N-1
                v = array.get(HP, s) * mvg_pdf(array.get(OB1,0), array.get(OB2,0), array.get(OB3,0), s)
                array.set(al, s, v)
                s0v += v
            s0v := math.max(s0v, 1e-300)
            array.set(sc, 0, s0v)
            for s = 0 to N-1
                array.set(al, s, array.get(al, s) / s0v)
            for t = 1 to T-1
                stv = 0.0
                for s = 0 to N-1
                    sm = 0.0
                    for p = 0 to N-1
                        sm += array.get(al, (t-1)*N+p) * array.get(HA, p*N+s)
                    v = sm * mvg_pdf(array.get(OB1,t), array.get(OB2,t), array.get(OB3,t), s)
                    array.set(al, t*N+s, v)
                    stv += v
                stv := math.max(stv, 1e-300)
                array.set(sc, t, stv)
                for s = 0 to N-1
                    array.set(al, t*N+s, array.get(al, t*N+s) / stv)

            be = array.new_float(T * N, 0.0)
            for s = 0 to N-1
                array.set(be, (T-1)*N+s, 1.0 / array.get(sc, T-1))
            for rv = 0 to T-2
                t   = T-2 - rv
                sct = array.get(sc, t)
                for s = 0 to N-1
                    sm = 0.0
                    for sn = 0 to N-1
                        bsn = mvg_pdf(array.get(OB1,t+1), array.get(OB2,t+1), array.get(OB3,t+1), sn)
                        sm += array.get(HA, s*N+sn) * bsn * array.get(be, (t+1)*N+sn)
                    array.set(be, t*N+s, sm / sct)

            gm = array.new_float(T * N, 0.0)
            for t = 0 to T-1
                gs = 0.0
                for s = 0 to N-1
                    g = array.get(al, t*N+s) * array.get(be, t*N+s)
                    array.set(gm, t*N+s, g)
                    gs += g
                gs := math.max(gs, 1e-300)
                for s = 0 to N-1
                    array.set(gm, t*N+s, array.get(gm, t*N+s) / gs)

            xi = array.new_float((T-1)*N*N, 0.0)
            for t = 0 to T-2
                xs = 0.0
                for i = 0 to N-1
                    for j = 0 to N-1
                        bj = mvg_pdf(array.get(OB1,t+1), array.get(OB2,t+1), array.get(OB3,t+1), j)
                        xv = array.get(al,t*N+i) * array.get(HA,i*N+j) * bj * array.get(be,(t+1)*N+j)
                        array.set(xi, t*N*N+i*N+j, xv)
                        xs += xv
                xs := math.max(xs, 1e-300)
                for i = 0 to N-1
                    for j = 0 to N-1
                        array.set(xi, t*N*N+i*N+j, array.get(xi, t*N*N+i*N+j) / xs)

            psum = 0.0
            for s = 0 to N-1
                psum += array.get(gm, s)
            psum := math.max(psum, 1e-300)
            for s = 0 to N-1
                array.set(HP, s, array.get(gm, s) / psum)

            for i = 0 to N-1
                di = 0.0
                for t = 0 to T-2
                    di += array.get(gm, t*N+i)
                for j = 0 to N-1
                    nij = 0.0
                    for t = 0 to T-2
                        nij += array.get(xi, t*N*N+i*N+j)
                    array.set(HA, i*N+j, math.max(di > 1e-300 ? nij/di : 1.0/N, 1e-8))
                rs = 0.0
                for j = 0 to N-1
                    rs += array.get(HA, i*N+j)
                if rs > 0
                    for j = 0 to N-1
                        array.set(HA, i*N+j, array.get(HA, i*N+j) / rs)

            for s = 0 to N-1
                gs2 = 0.0
                for t = 0 to T-1
                    gs2 += array.get(gm, t*N+s)
                has_occ      = gs2 >= float(T) * min_occ_pct
                occ_w        = math.min(gs2 / float(T), 1.0)
                adaptive_reg = reg_str * (1.0 - occ_w)
                for d = 0 to 2
                    if has_occ
                        wm = 0.0
                        for t = 0 to T-1
                            g     = array.get(gm, t*N+s)
                            obs_d = d == 0 ? array.get(OB1,t) : d == 1 ? array.get(OB2,t) : array.get(OB3,t)
                            wm   += g * obs_d
                        mu_bw = wm / gs2
                        mu_nd = (1.0 - adaptive_reg) * mu_bw + adaptive_reg * array.get(PRIOR_MU, s*3+d)
                        array.set(HMU, s*3+d, mu_nd)
                        wv = 0.0
                        for t = 0 to T-1
                            g     = array.get(gm, t*N+s)
                            obs_d = d == 0 ? array.get(OB1,t) : d == 1 ? array.get(OB2,t) : array.get(OB3,t)
                            diff  = obs_d - mu_nd
                            wv   += g * diff * diff
                        sg_bw = math.sqrt(wv / gs2)
                        sg_nd = (1.0 - adaptive_reg) * sg_bw + adaptive_reg * array.get(PRIOR_SG, s*3+d)
                        array.set(HSG, s*3+d, math.max(sg_nd, float(sig_floor)))
                    else
                        array.set(HMU, s*3+d, 0.7 * array.get(HMU, s*3+d) + 0.3 * array.get(PRIOR_MU, s*3+d))
                        array.set(HSG, s*3+d, math.max(0.7 * array.get(HSG, s*3+d) + 0.3 * array.get(PRIOR_SG, s*3+d), float(sig_floor)))

        // ── State label ordering ──────────────────────────────────
        m0v     = array.get(HMU, 0*3+0)
        m1v     = array.get(HMU, 1*3+0)
        m2v     = array.get(HMU, 2*3+0)
        bull_id = m0v >= m1v and m0v >= m2v ? 0 : m1v >= m2v ? 1 : 2
        bear_id = m0v <= m1v and m0v <= m2v ? 0 : m1v <= m2v ? 1 : 2
        side_id = bull_id == bear_id ? 2 : 3 - bull_id - bear_id
        if not (bull_id == 1 and bear_id == 2 and side_id == 0)
            mpv = array.new_int(3, 0)
            array.set(mpv, 0, side_id)
            array.set(mpv, 1, bull_id)
            array.set(mpv, 2, bear_id)
            tmu = array.new_float(9, 0.0)
            tsg = array.new_float(9, 0.0)
            tpi = array.new_float(3, 0.0)
            tA  = array.new_float(9, 0.0)
            for ni = 0 to 2
                oi = array.get(mpv, ni)
                array.set(tpi, ni, array.get(HP, oi))
                for d = 0 to 2
                    array.set(tmu, ni*3+d, array.get(HMU, oi*3+d))
                    array.set(tsg, ni*3+d, array.get(HSG, oi*3+d))
            for ni = 0 to 2
                oi = array.get(mpv, ni)
                for nj = 0 to 2
                    oj = array.get(mpv, nj)
                    array.set(tA, ni*3+nj, array.get(HA, oi*3+oj))
            for s = 0 to 2
                array.set(HP, s, array.get(tpi, s))
                for d = 0 to 2
                    array.set(HMU, s*3+d, array.get(tmu, s*3+d))
                    array.set(HSG, s*3+d, array.get(tsg, s*3+d))
            for idx = 0 to 8
                array.set(HA, idx, array.get(tA, idx))

        // ── Log-Viterbi ───────────────────────────────────────────
        NEG_INF = -1e30
        log_dl  = array.new_float(T * N, NEG_INF)
        psi_v   = array.new_int(T * N, 0)
        for s = 0 to N-1
            lp_s = array.get(HP, s) > 1e-300 ? math.log(array.get(HP, s)) : -500.0
            lb_s = log_mvg(array.get(OB1,0), array.get(OB2,0), array.get(OB3,0), s)
            array.set(log_dl, s, lp_s + lb_s)
        for t = 1 to T-1
            for s = 0 to N-1
                max_lv = NEG_INF
                max_pv = 0
                for p = 0 to N-1
                    la = array.get(HA, p*N+s) > 1e-300 ? math.log(array.get(HA, p*N+s)) : -500.0
                    lv = array.get(log_dl, (t-1)*N+p) + la
                    if lv > max_lv
                        max_lv := lv
                        max_pv := p
                lb_s = log_mvg(array.get(OB1,t), array.get(OB2,t), array.get(OB3,t), s)
                array.set(log_dl, t*N+s, max_lv + lb_s)
                array.set(psi_v,  t*N+s, max_pv)

        vpath = array.new_int(T, 0)
        lmx   = NEG_INF
        ls    = 0
        for s = 0 to N-1
            if array.get(log_dl, (T-1)*N+s) > lmx
                lmx := array.get(log_dl, (T-1)*N+s)
                ls  := s
        array.set(vpath, T-1, ls)
        for rv2 = 0 to T-2
            t = T-2 - rv2
            array.set(vpath, t, array.get(psi_v, (t+1)*N + array.get(vpath, t+1)))

        // ── [v4 NEW] Simpan raw Viterbi path sebelum smoothing ────
        // Digunakan untuk menghitung VDUR_RAW yang tidak terpengaruh
        // oleh duration smoothing — lebih mencerminkan state model sesungguhnya
        raw_vpath = array.copy(vpath)

        // ── [v4 FIX #1 & #3] Duration Smoothing yang Diperbaiki ──
        // BUG LAMA: cur_dur tidak bertambah saat transisi ditolak
        //           → state terkunci permanen karena cur_dur tidak pernah >= min_d
        // FIX BARU: cur_dur selalu bertambah setiap bar, terlepas transisi diterima/ditolak
        //           → setelah min_dur bars, transisi baru akan diterima
        cur_state = array.get(vpath, 0)
        cur_dur   = 1
        for t = 1 to T-1
            nxt = array.get(vpath, t)
            if nxt != cur_state
                min_d = cur_state == 0 ? min_dur_s : min_dur_b
                if cur_dur < min_d
                    // Tolak transisi: tahan di state lama
                    array.set(vpath, t, cur_state)
                    cur_dur += 1  // [v4 FIX] selalu increment, jangan biarkan stuck
                else
                    // Terima transisi: pindah ke state baru
                    cur_state := nxt
                    cur_dur   := 1
            else
                cur_dur += 1

        VR := array.get(vpath, T-1)

        // ── [v4 FIX #2] VDUR dari smoothed path (untuk info smoothing) ──
        dur_count = 0
        for dv = T-1 to 0
            if array.get(vpath, dv) == VR
                dur_count += 1
            else
                break
        VDUR := dur_count

        // ── [v4 NEW] VDUR_RAW dari Viterbi asli (lebih akurat) ───
        // Ini adalah durasi yang BENAR-BENAR dideteksi model sebelum smoothing
        // Jika VDUR >> VDUR_RAW, artinya smoothing terlalu agresif membekukan state
        raw_final = array.get(raw_vpath, T-1)
        raw_dur   = 0
        for dv2 = T-1 to 0
            if array.get(raw_vpath, dv2) == raw_final
                raw_dur += 1
            else
                break
        VDUR_RAW := raw_dur

        // ── Posterior gamma + Temperature Scaling ─────────────────
        a2  = array.new_float(T * N, 0.0)
        s2c = array.new_float(T, 1e-300)
        s0b = 0.0
        for s = 0 to N-1
            v = array.get(HP,s) * mvg_pdf(array.get(OB1,0), array.get(OB2,0), array.get(OB3,0), s)
            array.set(a2, s, v)
            s0b += v
        s0b := math.max(s0b, 1e-300)
        array.set(s2c, 0, s0b)
        for s = 0 to N-1
            array.set(a2, s, array.get(a2,s) / s0b)
        for t = 1 to T-1
            stb = 0.0
            for s = 0 to N-1
                sm = 0.0
                for p3 = 0 to N-1
                    sm += array.get(a2,(t-1)*N+p3) * array.get(HA,p3*N+s)
                v = sm * mvg_pdf(array.get(OB1,t), array.get(OB2,t), array.get(OB3,t), s)
                array.set(a2, t*N+s, v)
                stb += v
            stb := math.max(stb, 1e-300)
            array.set(s2c, t, stb)
            for s = 0 to N-1
                array.set(a2, t*N+s, array.get(a2,t*N+s) / stb)
        b2 = array.new_float(T * N, 0.0)
        for s = 0 to N-1
            array.set(b2,(T-1)*N+s, 1.0 / array.get(s2c, T-1))
        for rv3 = 0 to T-2
            t   = T-2 - rv3
            sct = array.get(s2c, t)
            for s = 0 to N-1
                sm = 0.0
                for sn = 0 to N-1
                    bsn = mvg_pdf(array.get(OB1,t+1), array.get(OB2,t+1), array.get(OB3,t+1), sn)
                    sm += array.get(HA,s*N+sn) * bsn * array.get(b2,(t+1)*N+sn)
                array.set(b2, t*N+s, sm / sct)

        gf = 0.0
        for s = 0 to N-1
            g = array.get(a2,(T-1)*N+s) * array.get(b2,(T-1)*N+s)
            array.set(VP, s, g)
            gf += g
        gf := math.max(gf, 1e-300)
        for s = 0 to N-1
            array.set(VP, s, array.get(VP,s) / gf)

        apply_temperature(VP, temp_scale)
        VC  := array.get(VP, VR)
        VCH := calc_conf_entropy(VP)

// ─── INSTANTANEOUS REGIME ────────────────────────────────────────────────────
lp0 = log_mvg(z_ret, z_atr, z_slope, 0) + math.log(math.max(array.get(HP,0), 1e-10))
lp1 = log_mvg(z_ret, z_atr, z_slope, 1) + math.log(math.max(array.get(HP,1), 1e-10))
lp2 = log_mvg(z_ret, z_atr, z_slope, 2) + math.log(math.max(array.get(HP,2), 1e-10))
IR  = lp1 >= lp0 and lp1 >= lp2 ? 1 : lp2 >= lp0 and lp2 >= lp1 ? 2 : 0

// ─── REGIME RIBBON & WARNING ─────────────────────────────────────────────────
rib_col = IR == 1 ? color.new(CB,30) : IR == 2 ? color.new(CR,30) : color.new(CS,30)
bgcolor(show_rib  ? rib_col : na, title="Regime Ribbon")
bgcolor(show_warn and IR == 0 ? CWN : na, title="Sideways Warning")

// ─── TRANSITION LABELS ───────────────────────────────────────────────────────
var int LR = na
held = not na(IR)
for k = 0 to min_hold - 1
    held := held and not na(IR[k]) and IR[k] == IR
if barstate.isconfirmed and not na(IR) and held and IR != LR
    if show_lbl and not na(LR)
        fo = min_hold - 1
        label.new(bar_index - fo, high[fo], rgn(LR) + " > " + rgn(IR),
             yloc=yloc.abovebar, style=label.style_label_down,
             color=rgc(IR), textcolor=CWT, size=size.normal)
    LR := IR

// ─── ATR & SL/TP ─────────────────────────────────────────────────────────────
atr_sl  = ta.atr(atr_len_sl)
sl_mult = VR == 1 ? atr_bull : VR == 2 ? atr_bear : float(na)
sl_val  = na(sl_mult) ? float(na) : atr_sl * sl_mult
tp_val  = na(sl_val)  ? float(na) : sl_val * rr_r

// ─── TABLE DECLARATIONS ──────────────────────────────────────────────────────
var table TBAN = table.new(gpos(ban_ps), 1, 6, bgcolor=color.new(color.black,30), border_width=0)
var table TMAT = table.new(gpos(mat_ps), 5, 7, bgcolor=CK, border_width=2, border_color=CK, frame_color=CF, frame_width=1)
var table TSTT = table.new(gpos(stt_ps), 4, 5, bgcolor=CK, border_width=2, border_color=CK, frame_color=CF, frame_width=1)
var table TSLT = table.new(gpos(slt_ps), 2, 6, bgcolor=CK, border_width=2, border_color=CK, frame_color=CF, frame_width=1)
var table TEMT = table.new(gpos(emt_ps), 8, 6, bgcolor=CK, border_width=2, border_color=CK, frame_color=CF, frame_width=1)

// ─── TABLE POPULATION ────────────────────────────────────────────────────────
if barstate.islast
    exp_d0 = array.get(HA,0) < 1.0 ? 1.0 / (1.0 - array.get(HA,0)) : 99.0
    exp_d1 = array.get(HA,4) < 1.0 ? 1.0 / (1.0 - array.get(HA,4)) : 99.0
    exp_d2 = array.get(HA,8) < 1.0 ? 1.0 / (1.0 - array.get(HA,8)) : 99.0

    MS  = array.copy(HA)
    for _si = 0 to stat_pow - 1
        MS := mm3(MS, HA)
    st0 = array.get(MS, 0)
    st1 = array.get(MS, 1)
    st2 = array.get(MS, 2)

    conf_str   = fmtp(VC)
    conf_h_str = fmtp(VCH)
    zr_str     = fmtf(z_ret)
    za_str     = fmtf(z_atr)
    zs_str     = fmtf(z_slope)

    // [v4] Deteksi smoothing lock: jika VDUR jauh lebih besar dari VDUR_RAW
    // ini sinyal bahwa duration smoothing sedang membekukan state secara tidak wajar
    is_locked   = VDUR > VDUR_RAW * 2 and VDUR_RAW > 0
    dur_str     = str.tostring(VDUR) + "b(s)/" + str.tostring(VDUR_RAW) + "b(r)"
    dur_col     = is_locked ? color.rgb(255, 100, 100) : CDT
    lock_warn   = is_locked ? " ⚠ LOCK" : ""

    // ── BANNER ────────────────────────────────────────────────────
    if show_ban
        table.cell(TBAN, 0, 0, "HMM Regime: " + rgi(VR),
             text_color=CWT, bgcolor=color.new(rgc(VR),30),
             text_size=gsz("large"), text_halign=text.align_center)
        table.cell(TBAN, 0, 1, rgd(VR),
             text_color=VR == 0 ? color.rgb(255,200,0) : CWT,
             bgcolor=color.new(color.black,50), text_size=sh, text_halign=text.align_center)
        table.cell(TBAN, 0, 2,
             "Conf(γ): " + conf_str + "  |  Conf(H): " + conf_h_str +
             "  |  T=" + str.tostring(temp_scale,"#.#"),
             text_color=CDT, bgcolor=color.new(color.black,60),
             text_size=sh, text_halign=text.align_center)
        // [v4] Tampilkan smoothed(s) vs raw(r) duration + lock warning
        table.cell(TBAN, 0, 3,
             "Dur: " + dur_str + lock_warn +
             "  |  Z ret=" + zr_str + " atr=" + za_str + " slope=" + zs_str,
             text_color=dur_col, bgcolor=color.new(color.black,65),
             text_size=sh, text_halign=text.align_center)
        table.cell(TBAN, 0, 4,
             "ATR=" + fmtf(atr_sl) + "  |  win=" + str.tostring(hmm_win) +
             "b  |  BW=" + str.tostring(bw_n) + "it  |  D=3  |  slp=" + str.tostring(slope_per) + "b",
             text_color=CFT, bgcolor=color.new(color.black,70),
             text_size=sh, text_halign=text.align_center)
        conf_lvl = VCH >= 0.70 ? "STRONG" : VCH >= 0.45 ? "MODERATE" : "WEAK"
        conf_col = VCH >= 0.70 ? CB : VCH >= 0.45 ? color.rgb(255,200,0) : CR
        table.cell(TBAN, 0, 5, "Signal Strength: " + conf_lvl + "  (target: 45-75%)",
             text_color=conf_col, bgcolor=color.new(color.black,75),
             text_size=sh, text_halign=text.align_center)

    // ── TRANSITION MATRIX ─────────────────────────────────────────
    if show_mat
        table.cell(TMAT, 0, 0, "TRANSITION MATRIX",
             text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_left)
        table.cell(TMAT, 1, 0, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TMAT, 2, 0, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TMAT, 3, 0, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TMAT, 4, 0, "Baum-Welch",
             text_color=CFT, bgcolor=CK, text_size=sh, text_halign=text.align_right)

        table.cell(TMAT, 0, 1, "DARI \\ KE", text_color=CHD, bgcolor=CK, text_size=sh)
        table.cell(TMAT, 1, 1, "SIDE", text_color=CS,  bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TMAT, 2, 1, "BULL", text_color=CB,  bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TMAT, 3, 1, "BEAR", text_color=CR,  bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TMAT, 4, 1, "E[dur]", text_color=CDT, bgcolor=CK, text_size=sh, text_halign=text.align_center)

        exp_durs = array.new_float(3, 0.0)
        array.set(exp_durs, 0, exp_d0)
        array.set(exp_durs, 1, exp_d1)
        array.set(exp_durs, 2, exp_d2)
        rnames2 = array.new_string(3, "")
        array.set(rnames2, 0, "SIDE")
        array.set(rnames2, 1, "BULL")
        array.set(rnames2, 2, "BEAR")

        for r3 = 0 to 2
            isCur = r3 == VR
            rowBg = isCur ? color.new(CA, 78) : CK
            table.cell(TMAT, 0, r3+2, array.get(rnames2, r3),
                 text_color=isCur ? CWT : CHD, bgcolor=rowBg, text_size=sh)
            for c3 = 0 to 2
                p3     = array.get(HA, r3*3+c3)
                isDiag = r3 == c3
                isHi   = isCur and c3 == VR
                cBg    = isHi ? color.new(color.yellow,40) : isDiag ? CDG : CK
                cTxt   = isDiag ? CDT : (isCur ? CWT : COF)
                table.cell(TMAT, c3+1, r3+2, fmtp(p3),
                     text_color=cTxt, bgcolor=cBg, text_size=sh, text_halign=text.align_center)
            table.cell(TMAT, 4, r3+2, fmtd(array.get(exp_durs, r3)),
                 text_color=CDT, bgcolor=CDG, text_size=sh, text_halign=text.align_center)

        table.cell(TMAT, 0, 5, "P(state|obs)",
             text_color=CFT, bgcolor=CK, text_size=sh)
        table.cell(TMAT, 1, 5, fmtp(array.get(VP,0)),
             text_color=CS, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TMAT, 2, 5, fmtp(array.get(VP,1)),
             text_color=CB, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TMAT, 3, 5, fmtp(array.get(VP,2)),
             text_color=CR, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        // [v4] Tampilkan kedua durasi: smoothed(s) dan raw(r)
        table.cell(TMAT, 4, 5, "s=" + str.tostring(VDUR) + "b r=" + str.tostring(VDUR_RAW) + "b",
             text_color=dur_col, bgcolor=CK, text_size=sh, text_halign=text.align_right)

        table.cell(TMAT, 0, 6, "next-state probability",
             text_color=CFT, bgcolor=CK, text_size=sh)
        table.cell(TMAT, 1, 6, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TMAT, 2, 6, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TMAT, 3, 6, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TMAT, 4, 6, "Log-Viterbi",
             text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_right)

    // ── EMISSION PARAMETERS ───────────────────────────────────────
    if show_emit
        table.cell(TEMT, 0, 0, "EMISSION  (D=3 multivariate)",
             text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_left)
        table.cell(TEMT, 1, 0, "mu_ret",   text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 2, 0, "mu_atr",   text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 3, 0, "mu_slope", text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 4, 0, "sg_ret",   text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 5, 0, "sg_atr",   text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 6, 0, "P(state)", text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 7, 0, "E[dur]",   text_color=CHD, bgcolor=CK, text_size=sh, text_halign=text.align_center)

        enames2 = array.new_string(3, "")
        array.set(enames2, 0, "SIDE")
        array.set(enames2, 1, "BULL")
        array.set(enames2, 2, "BEAR")
        ecols2 = array.new_color(3, CS)
        array.set(ecols2, 0, CS)
        array.set(ecols2, 1, CB)
        array.set(ecols2, 2, CR)

        for s5 = 0 to 2
            isCur5 = s5 == VR
            rowBg5 = isCur5 ? color.new(CA,80) : CK
            ec     = array.get(ecols2, s5)
            exp_dv = s5 == 0 ? exp_d0 : s5 == 1 ? exp_d1 : exp_d2
            table.cell(TEMT, 0, s5+1, array.get(enames2, s5) + (isCur5 ? " <" : ""),
                 text_color=isCur5 ? CWT : ec, bgcolor=rowBg5, text_size=sh)
            table.cell(TEMT, 1, s5+1, fmtf(array.get(HMU, s5*3+0)),
                 text_color=isCur5 ? CWT : CDT, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)
            table.cell(TEMT, 2, s5+1, fmtf(array.get(HMU, s5*3+1)),
                 text_color=isCur5 ? CWT : CDT, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)
            table.cell(TEMT, 3, s5+1, fmtf(array.get(HMU, s5*3+2)),
                 text_color=isCur5 ? CWT : CDT, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)
            table.cell(TEMT, 4, s5+1, fmtf(array.get(HSG, s5*3+0)),
                 text_color=isCur5 ? CWT : COF, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)
            table.cell(TEMT, 5, s5+1, fmtf(array.get(HSG, s5*3+1)),
                 text_color=isCur5 ? CWT : COF, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)
            table.cell(TEMT, 6, s5+1, fmtp(array.get(VP, s5)) + (isCur5 ? " *" : ""),
                 text_color=isCur5 ? color.yellow : COF, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)
            table.cell(TEMT, 7, s5+1, fmtd(exp_dv) + (isCur5 ? "/" + str.tostring(VDUR_RAW) + "b" : ""),
                 text_color=isCur5 ? CDT : COF, bgcolor=rowBg5, text_size=sh, text_halign=text.align_center)

        table.cell(TEMT, 0, 4, "Z current",
             text_color=CFT, bgcolor=CK, text_size=sh)
        table.cell(TEMT, 1, 4, zr_str, text_color=CWT, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 2, 4, za_str, text_color=CWT, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 3, 4, zs_str, text_color=CWT, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TEMT, 4, 4, "", text_color=CFT, bgcolor=CK, text_size=sh)
        table.cell(TEMT, 5, 4, "", text_color=CFT, bgcolor=CK, text_size=sh)
        table.cell(TEMT, 6, 4, "BW=" + str.tostring(bw_n) + " T=" + str.tostring(temp_scale,"#.#"),
             text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_right)
        table.cell(TEMT, 7, 4, "slp=" + str.tostring(slope_per) + "b dur.min=" + str.tostring(min_dur_s) + "/" + str.tostring(min_dur_b),
             text_color=CFT, bgcolor=CK, text_size=sh, text_halign=text.align_center)

    // ── STATIONARY DISTRIBUTION ───────────────────────────────────
    if show_stat
        table.cell(TSTT, 0, 0, "LONG-RUN DISTRIBUTION",
             text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_left)
        table.cell(TSTT, 1, 0, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TSTT, 2, 0, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TSTT, 3, 0, "A^" + str.tostring(stat_pow),
             text_color=CFT, bgcolor=CK, text_size=sh, text_halign=text.align_right)
        table.cell(TSTT, 0, 1, "SIDE", text_color=CS,  bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 1, 1, "BULL", text_color=CB,  bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 2, 1, "BEAR", text_color=CR,  bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 3, 1, "Conf(H)", text_color=CDT, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 0, 2, fmtp(st0), text_color=CDT, bgcolor=CDG, text_size=sv, text_halign=text.align_center, text_valign=text.align_center)
        table.cell(TSTT, 1, 2, fmtp(st1), text_color=CDT, bgcolor=CDG, text_size=sv, text_halign=text.align_center, text_valign=text.align_center)
        table.cell(TSTT, 2, 2, fmtp(st2), text_color=CDT, bgcolor=CDG, text_size=sv, text_halign=text.align_center, text_valign=text.align_center)
        table.cell(TSTT, 3, 2, conf_h_str, text_color=CDT, bgcolor=CDG, text_size=sv, text_halign=text.align_center, text_valign=text.align_center)
        table.cell(TSTT, 0, 3, "steady state — distribusi jangka panjang",
             text_color=CFT, bgcolor=CK, text_size=sh, text_halign=text.align_left)
        table.cell(TSTT, 1, 3, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TSTT, 2, 3, "", bgcolor=CK, text_color=CFT, text_size=sh)
        table.cell(TSTT, 3, 3, "live", text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_right)
        table.cell(TSTT, 0, 4, "current gamma (T-scaled)",
             text_color=CFT, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 1, 4, fmtp(array.get(VP,0)),
             text_color=CS, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 2, 4, fmtp(array.get(VP,1)),
             text_color=CB, bgcolor=CK, text_size=sh, text_halign=text.align_center)
        table.cell(TSTT, 3, 4, fmtp(array.get(VP,2)),
             text_color=CR, bgcolor=CK, text_size=sh, text_halign=text.align_center)

    // ── DST KALKULASI ─────────────────────────────────────────────
    if show_sltp
        table.cell(TSLT, 0, 0, "DST KALKULASI",
             text_color=CA, bgcolor=CK, text_size=sh, text_halign=text.align_left)
        table.cell(TSLT, 1, 0, "XAUUSD",
             text_color=CFT, bgcolor=CK, text_size=sh, text_halign=text.align_right)
        table.cell(TSLT, 0, 1, "Regime",
             text_color=CHD, bgcolor=CK, text_size=sh)
        table.cell(TSLT, 1, 1, rgn(VR) + " (H:" + conf_h_str + ")",
             text_color=VR == 0 ? color.rgb(255,200,0) : CDT,
             bgcolor=CK, text_size=sv, text_halign=text.align_right)
        sl_lbl  = na(sl_mult) ? "N/A" : "ATR x " + str.tostring(sl_mult,"#.#")
        sl_text = na(sl_val)  ? "N/A" : fmtf(sl_val) + " pts"
        table.cell(TSLT, 0, 2, sl_lbl, text_color=CHD, bgcolor=CK, text_size=sh)
        table.cell(TSLT, 1, 2, "SL: " + sl_text,
             text_color=CR, bgcolor=CK, text_size=sv, text_halign=text.align_right)
        tp_lbl  = na(sl_mult) ? "N/A" : "RR 1:" + str.tostring(rr_r,"#.#")
        tp_text = na(tp_val)  ? "N/A" : fmtf(tp_val) + " pts"
        table.cell(TSLT, 0, 3, tp_lbl, text_color=CHD, bgcolor=CK, text_size=sh)
        table.cell(TSLT, 1, 3, "TP: " + tp_text,
             text_color=CDT, bgcolor=CK, text_size=sv, text_halign=text.align_right)
        partial = na(sl_val) ? "N/A" : fmtf(sl_val) + " pts"
        table.cell(TSLT, 0, 4, "Partial TP 1:1", text_color=CHD, bgcolor=CK, text_size=sh)
        table.cell(TSLT, 1, 4, partial,
             text_color=color.new(CDT,30), bgcolor=CK, text_size=sh, text_halign=text.align_right)
        table.cell(TSLT, 0, 5, "STATUS", text_color=CFT, bgcolor=CK, text_size=sh)
        table.cell(TSLT, 1, 5, rgs(VR),
             text_color=rgsc(VR), bgcolor=CK, text_size=sv, text_halign=text.align_right)
